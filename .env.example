# Copia este archivo como .env y llena los valores
NODE_ENV=development
PORT=3000

# Base de datos (NeonDB)
DATABASE_URL=postgresql://usuario:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=tu_secreto_jwt_super_seguro_aqui

# OpenAI (para chatbot IA)
OPENAI_API_KEY=sk-tu-api-key

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_password_de_app

# Google Auth
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret
CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# AWS S3 (para carga de imágenes)
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=tu_bucket_name
